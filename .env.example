# Render Web Service → Environment (do not commit real values)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
SECRET_KEY=

# Optional: overrides DB_* if set
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: default is require on *.render.com hosts
# PGSSLMODE=require

# Optional
# PG_CONNECT_TIMEOUT=10
# FLASK_DEBUG=false
