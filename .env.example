# Render Web Service — set these in the dashboard, NOT in git.
DB_HOST=your-host.oregon-postgres.render.com
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password
SECRET_KEY=long-random-string-for-flask-sessions

# Optional: use full URL instead of DB_* (then sslmode can be in URL or use PGSSLMODE)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# SSL: Render external Postgres usually needs require (default when host contains render.com)
# PGSSLMODE=require

# Production: leave unset or false
# FLASK_DEBUG=false
