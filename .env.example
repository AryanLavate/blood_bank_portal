# --- Option A: Render (recommended) ---
# Copy from Render PostgreSQL dashboard as "External Database URL"
# DATABASE_URL=postgresql://user:password@host.region.render.com/dbname

# If your URL has no sslmode and Render requires SSL:
# PGSSLMODE=require

# --- Option B: Local PostgreSQL (no DATABASE_URL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=blood_bank_portal

# --- App ---
SECRET_KEY=replace-with-a-strong-random-secret
FLASK_DEBUG=true

# Local dev without SSL to localhost:
# PGSSLMODE=disable
